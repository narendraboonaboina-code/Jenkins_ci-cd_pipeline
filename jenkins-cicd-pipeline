pipeline {
    agent any

    tools {
        maven 'Maven-3.9.0'
        jdk 'JDK-17'
    }

    environment {
        SONAR_TOKEN = credentials('sonar-token')
        NEXUS_URL = 'http://localhost:8081'
        NEXUS_REPO = 'maven-releases'
        APP_NAME = 'my-java-app'
        TOMCAT_URL = 'http://localhost:8080'
        TOMCAT_CREDENTIALS = credentials('tomcat-credentials')
    }

    stages {

        stage('Git Checkout') {
            steps {
                echo '📥 Cloning source code from Git...'
                git branch: 'main', url: 'https://github.com/YOUR_USERNAME/jenkins-cicd-pipeline.git'
            }
        }

        stage('Maven Build') {
            steps {
                echo '🔨 Building the project with Maven...'
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Run Unit Tests') {
            steps {
                echo '🧪 Running Unit Tests...'
                sh 'mvn test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Code Quality Analysis') {
            steps {
                echo '🔍 Running SonarQube Analysis...'
                withSonarQubeEnv('SonarQube-Server') {
                    sh '''
                        mvn sonar:sonar \
                        -Dsonar.projectKey=my-java-app \
                        -Dsonar.projectName="My Java App" \
                        -Dsonar.token=${SONAR_TOKEN}
                    '''
                }
            }
        }

        stage('Quality Gate Check') {
            steps {
                echo '✅ Checking SonarQube Quality Gate...'
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Upload Artifact to Nexus') {
            steps {
                echo '📦 Uploading artifact to Nexus Repository...'
                nexusArtifactUploader(
                    nexusVersion: 'nexus3',
                    protocol: 'http',
                    nexusUrl: "${NEXUS_URL}",
                    groupId: 'com.myapp',
                    version: "${BUILD_NUMBER}",
                    repository: "${NEXUS_REPO}",
                    credentialsId: 'nexus-credentials',
                    artifacts: [[
                        artifactId: "${APP_NAME}",
                        type: 'war',
                        file: "target/${APP_NAME}.war"
                    ]]
                )
            }
        }

        stage('Deploy to Tomcat') {
            steps {
                echo '🚀 Deploying to Tomcat Server...'
                deploy adapters: [
                    tomcat9(
                        credentialsId: 'tomcat-credentials',
                        path: '/my-java-app',
                        url: "${TOMCAT_URL}"
                    )
                ],
                contextPath: null,
                war: 'target/*.war'
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline SUCCESS!'
            mail to: 'yourmail@example.com',
                 subject: "✅ Build #${BUILD_NUMBER} - SUCCESS",
                 body: "Project ${APP_NAME} build and deployment was successful!\n\nCheck: ${BUILD_URL}"
        }
        failure {
            echo '❌ Pipeline FAILED!'
            mail to: 'yourmail@example.com',
                 subject: "❌ Build #${BUILD_NUMBER} - FAILED",
                 body: "Project ${APP_NAME} build failed.\n\nCheck logs: ${BUILD_URL}"
        }
    }
}
